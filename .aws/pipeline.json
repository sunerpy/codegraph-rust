{
  "pipeline": {
    "name": "${PIPELINE_NAME}",
    "roleArn": "${PIPELINE_ROLE_ARN}",
    "pipelineType": "V2",
    "executionMode": "QUEUED",
    "artifactStore": {
      "type": "S3",
      "location": "${ARTIFACT_BUCKET}"
    },
    "stages": [
      {
        "name": "Source",
        "actions": [
          {
            "name": "CodeCommit",
            "actionTypeId": {
              "category": "Source",
              "owner": "AWS",
              "provider": "CodeCommit",
              "version": "1"
            },
            "configuration": {
              "RepositoryName": "${CODECOMMIT_REPO}",
              "BranchName": "${CI_BRANCH}",
              "PollForSourceChanges": "false"
            },
            "outputArtifacts": [{ "name": "SourceOutput" }],
            "runOrder": 1
          }
        ]
      },
      {
        "name": "Build",
        "actions": [
          {
            "name": "Linux",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": { "ProjectName": "${PROJECT_LINUX}" },
            "inputArtifacts": [{ "name": "SourceOutput" }],
            "runOrder": 1
          },
          {
            "name": "Windows",
            "actionTypeId": {
              "category": "Build",
              "owner": "AWS",
              "provider": "CodeBuild",
              "version": "1"
            },
            "configuration": { "ProjectName": "${PROJECT_WINDOWS}" },
            "inputArtifacts": [{ "name": "SourceOutput" }],
            "runOrder": 1
          }
        ]
      }
    ]
  }
}
